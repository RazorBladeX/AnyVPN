{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window permissions for AnyVPN",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "notification:default",
    "opener:default",
    "process:default",
    "os:default",
    "store:default",
    "shell:allow-open",
    "autostart:default"
  ]
}
